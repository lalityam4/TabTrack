{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Splash Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".claude"],
      "port": 3457,
      "autoPort": true
    },
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 19006
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:android"],
      "port": 8081
    }
  ]
}
